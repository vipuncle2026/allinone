{
  "name": "allinone-desktop",
  "version": "1.0.0",
  "description": "All-in-One 个人管理系统 - Electron 桌面端",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.allinone.desktop",
    "productName": "AllInOne",
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/allinone-api",
        "to": "allinone-api"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend-dist"
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
